# Copy this file to .env and override values as needed.
# All required secrets MUST be provided via environment variables.

# ---- Application ----
APP_ENV=development
APP_NAME=Job Recruitment Platform
API_V1_PREFIX=/api/v1

# ---- Security (REQUIRED) ----
# 32+ characters. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-long-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BCRYPT_ROUNDS=12

# ---- Database (REQUIRED) ----
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/appdb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30

# ---- HR Registration (REQUIRED) ----
# Code that must be supplied when registering an HR account.
HR_INVITE_CODE=hr-invite-code-min-8-chars

# ---- CORS ----
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ---- Seeding (optional; for assessment / dev only) ----
SEED_DATA=true
SEED_HR_EMAIL=admin@test.com
SEED_HR_PASSWORD=Admin@1234
SEED_HR_NAME=HR Admin
SEED_CANDIDATE_EMAIL=user@test.com
SEED_CANDIDATE_PASSWORD=User@1234
SEED_CANDIDATE_NAME=Test Candidate

# ---- Uvicorn ----
UVICORN_WORKERS=2
