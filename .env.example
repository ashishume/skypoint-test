# Copy to .env to override docker-compose defaults.
# Defaults in docker-compose.yml are development-only — set real values
# in .env before running in any non-local environment.

# ---- Database ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
# Used when running the backend outside Docker. Docker Compose overrides this
# to point at the `db` service inside the Compose network.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/appdb

# ---- Application / backend security (CHANGE IN PRODUCTION) ----
APP_ENV=development
APP_NAME=RecruitFlow
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-me-with-a-long-random-string-min-32-chars
HR_INVITE_CODE=hr-invite-code-min-8-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BCRYPT_ROUNDS=12

# ---- Backend tuning ----
APP_ENV=development
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30
UVICORN_WORKERS=2

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:80
RATE_LIMIT_AUTH_MAX_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_STORE=redis
REDIS_URL=redis://redis:6379/0

# ---- Seed Data (assessment / dev users + demo workspace) ----
SEED_DATA=true
SEED_HR_EMAIL=admin@test.com
SEED_HR_PASSWORD=Admin@1234
SEED_HR_NAME=HR Admin
SEED_CANDIDATE_EMAIL=user@test.com
SEED_CANDIDATE_PASSWORD=User@1234
SEED_CANDIDATE_NAME=Test Candidate

# ---- Ports ----
BACKEND_PORT=8000
FRONTEND_PORT=5173
REDIS_PORT=6379
